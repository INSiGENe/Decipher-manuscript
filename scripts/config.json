  "cz_human_kidney_v1.5": {
    "dataset_description":{
      "repository": "cellxgene",
      "download_url": "https://datasets.cellxgene.cziscience.com/f5b6d620-76df-45c5-9524-e5631be0e44a.h5ad",
      "description": "Single-cell RNA-seq of the Adult Human Kidney (Version 1.5)",
      "abbreviation": "cz_human_kidney_v1.5",
      "url": "https://cellxgene.cziscience.com/collections/0f528c8a-a25c-4840-8fa3-d156fa11086f"
    },
    "pre_processing":{
      "input_path": "data/cz_human_kidney_v1.5",
      "output_path": "data/cz_human_kidney_v1.5",
      "step": "preprocessing",
      "subset_logic": {
        "disease": ["chronic kidney disease", "normal"]
      },
      "min_genes_per_cell": 200
    },
    "pre_processing_for_analysis": {
      "input_path": "data/cz_human_kidney_v1.5/preprocessing",
      "output_path": "results/cz_human_kidney_v1.5",
      "cluster_meta_field": "cell_type",
      "condition_meta_field": "disease",
      "individual_meta_field": "donor_id",
      "case_condition": "chronic kidney disease",
      "control_condition": "normal"
    },
    "cytosig": {
      "output_path": "results/cz_human_kidney_v1.5"
    },
    "cell_oracle": {
      "data_folder": "results/cz_human_kidney_v1.5",
      "species": "human"
    },
    "Decipher_analysis": {
      "min_cells_per_cluster_condition": 100,
      "species": "human",
      "dataset_path": "results/cz_human_kidney_v1.5",
      "condition_name": "condition",
      "case_condition": "chronic kidney disease",
      "control_condition": "normal",
      "k_parameter": 2,
      "min_meta_cells_parameter": 100
    },
    "Connectome_analysis": {
      "this_species":"human",
      "case_condition":"chronic kidney disease", 
      "control_condition":"normal", 
      "dataset_path":"results/cz_human_kidney_v1.5"
    },
    "NicheNet_analysis": {
      "case_condition": "chronic kidney disease",
      "control_condition": "normal",
      "dataset_path": "results/cz_human_kidney_v1.5",
      "this_species": "human"
    },
    "liana_plus_analysis":{
      "dataset_path": "results/cz_human_kidney_v1.5",
      "sample_key": "donor_id",
      "groupby": "cluster",
      "condition_key": "condition"
    }
  },

  
