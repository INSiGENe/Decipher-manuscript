  "cz_rcc": {
    "dataset_description":{
      "repository": "cellxgene",
      "download_url": "https://datasets.cellxgene.cziscience.com/bf28d870-0750-443d-bb54-ec664b8f40c3.h5ad",
      "description": "Single-cell transcriptomic datasets of Renal cell carcinoma patients",
      "abbreviation": "cz_rcc"
    },
    "pre_processing":{
      "input_path": "data/cz_rcc",
      "output_path": "data/cz_rcc",
      "step": "preprocessing",
      "subset_logic": {
        "disease": ["nonpapillary renal cell carcinoma", "normal"]
      },
      "min_genes_per_cell": 200
    },
    "pre_processing_for_analysis": {
      "input_path": "data/cz_rcc/preprocessing",
      "output_path": "results/cz_rcc",
      "cluster_meta_field": "cell_type",
      "condition_meta_field": "disease",
      "individual_meta_field": "donor_id",
      "case_condition": "nonpapillary renal cell carcinoma",
      "control_condition": "normal"
    },
    "cytosig": {
      "output_path": "results/cz_rcc"
    }
  },



