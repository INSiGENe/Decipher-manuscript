# doing something to speed up pubmed retrieval

library(dplyr)

# Combine all data frames in capped_regulons_all_clusters into one data frame
combined_df <- bind_rows(capped_regulons_all_clusters, .id = "cluster")

# Remove rows where 'source' contains 'sample' (e.g., "sample1", "sample2", etc.)
combined_df <- combined_df %>%
  filter(!grepl("^sample\\d+", source))

# Count the occurrences of each unique target across all data frames
target_counts <- combined_df %>%
  group_by(target) %>%
  summarise(count = n()) %>%
  arrange(desc(count))

# Display the result
print(target_counts)

table(target_counts$count >1)

genes_to_query <- target_counts$target[which(target_counts$count >1)]

# Apply the function to each gene and store the results in a data frame
gene_counts_all_relevant_to_datset <- data.frame(
  Gene = genes_to_query,
  PubMed_Count = sapply(genes_to_query, get_pubmed_count)
)


library(progress)

# Initialize an empty data frame to store results
gene_counts_all_relevant_to_dataset <- data.frame(Gene = character(), PubMed_Count = integer(), stringsAsFactors = FALSE)


# Initialize the progress bar
pb <- progress_bar$new(
  format = "  Querying [:bar] :percent in :elapsed",
  total = length(genes_to_query),
  clear = FALSE,
  width = 60
)


# Loop through each gene and retrieve the PubMed count
for (gene in genes_to_query) {
  # Add a delay to avoid overloading the API
  Sys.sleep(0.5)

  # Try to get the count, with error handling
  count <- tryCatch({
    search_result <- entrez_search(db = "pubmed", term = gene)
    search_result$count
  }, error = function(e) {
    message(paste("Error retrieving data for gene:", gene))
    NA  # Assign NA if there is an error
  })

  # Append the result to the data frame
  gene_counts_all_relevant_to_dataset <- rbind(
    gene_counts_all_relevant_to_dataset,
    data.frame(Gene = gene, PubMed_Count = count, stringsAsFactors = FALSE)
  )

  # Update the progress bar
  pb$tick()

}
