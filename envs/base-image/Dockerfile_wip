FROM r-base:4.5.1

# Set the working directory
WORKDIR /usr/src/app

#install system dependencies
RUN apt-get update && apt-get install -y -t testing --no-install-recommends --allow-downgrades \
    gfortran \
    libcurl4t64=8.15.0-1 \
    libcurl4-openssl-dev \
    libgraphite2-3=1.3.14-3\
    libssl-dev \
    libxml2-dev \
    libcairo2-dev \
    libxt-dev \
    libharfbuzz-dev \
    libfribidi-dev \
    libfreetype6-dev \
    libpng-dev \
    libjpeg-dev \
    libtiff5-dev \
    libwebp-dev \
    libgit2-dev \
    libglpk-dev \
    pandoc \
    pkg-config \
    libfontconfig1-dev \
    libhdf5-dev \
    build-essential \
    wget \
    ca-certificates \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Copy renv.lock and renv/ folder first for caching
COPY renv.lock renv.lock
COPY renv/ renv/

# Install renv
RUN R -e "install.packages('renv')"

# Restore R environment
RUN R -e "renv::restore(lockfile = 'renv.lock', prompt = FALSE)"

# --- after your existing apt install & clean block ---
# install gdebi or use dpkg fallback (we already have curl/wget from your earlier step)
RUN apt-get update \
 && apt-get install -y --no-install-recommends gdebi-core \
 && rm -rf /var/lib/apt/lists/*

# download and install Quarto CLI (.deb)
RUN curl -fsSL -o /tmp/quarto.deb "https://quarto.org/download/latest/quarto-linux-amd64.deb" \
 && dpkg -i /tmp/quarto.deb || true \
 && apt-get update && apt-get -y -f install \
 && rm -f /tmp/quarto.deb \
 && rm -rf /var/lib/apt/lists/*

# Copy your R project files (including renv.lock)
COPY . .


