FROM r-base:4.5.1

# Set the working directory
WORKDIR /usr/src/app

#install system dependencies
RUN apt-get update && apt-get install -y -t testing --no-install-recommends --allow-downgrades \
    gfortran \
    libcurl4t64=8.15.0-1 \
    libcurl4-openssl-dev \
    libgraphite2-3=1.3.14-3\
    libssl-dev \
    libxml2-dev \
    libcairo2-dev \
    libxt-dev \
    libharfbuzz-dev \
    libfribidi-dev \
    libfreetype6-dev \
    libpng-dev \
    libjpeg-dev \
    libtiff5-dev \
    libwebp-dev \
    libgit2-dev \
    libglpk-dev \
    pandoc \
    pkg-config \
    libfontconfig1-dev \
    libhdf5-dev \
    build-essential \
    wget \
    ca-certificates \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Create a persistent renv cache dir
ENV RENV_PATHS_CACHE=/renv/cache
RUN mkdir -p ${RENV_PATHS_CACHE} && chmod -R 777 ${RENV_PATHS_CACHE}

# (Optional) Install renv so that it's already available in base R.
# This step is not strictly required: renv can auto-install itself on the fly
# if you prefer. But having it pre-installed often avoids potential bootstrapping errors.
RUN R -e 'install.packages("renv", repos="https://cloud.r-project.org")'

# Install renv and BiocManager quickly (system-wide)
RUN R -e "options(repos='https://cloud.r-project.org'); install.packages(c('renv','BiocManager'), dependencies=TRUE)"

# --- COPY only the lockfile first to leverage Docker cache ---
COPY renv.lock /usr/src/app/renv.lock

# ENV RENV_PATHS_CACHE already set earlier
RUN R -e "options(repos='https://cloud.r-project.org'); \
          renv::restore(prompt = FALSE)"

# --- after your existing apt install & clean block ---
# install gdebi or use dpkg fallback (we already have curl/wget from your earlier step)
RUN apt-get update \
 && apt-get install -y --no-install-recommends gdebi-core \
 && rm -rf /var/lib/apt/lists/*

# download and install Quarto CLI (.deb)
RUN curl -fsSL -o /tmp/quarto.deb "https://quarto.org/download/latest/quarto-linux-amd64.deb" \
 && dpkg -i /tmp/quarto.deb || true \
 && apt-get update && apt-get -y -f install \
 && rm -f /tmp/quarto.deb \
 && rm -rf /var/lib/apt/lists/*

# Now copy the rest of your project (SOURCE) after restore (so cache layer benefits)
COPY . /usr/src/app